<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
	<cloud-backup>
		<exclude domain="file" path="accounts.json"/>
		<exclude domain="file" path="accounts.json~"/>
		<exclude domain="sharedpref" path="push.xml"/>
		<exclude domain="sharedpref" path="account_manager.xml"/>
	</cloud-backup>
	<device-transfer>
		<exclude domain="file" path="accounts.json"/>
		<exclude domain="file" path="accounts.json~"/>
		<exclude domain="sharedpref" path="push.xml"/>
		<exclude domain="sharedpref" path="account_manager.xml"/>
	</device-transfer>
</data-extraction-rules>
